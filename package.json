{
  "name": "opencove-extension",
  "displayName": "OpenCove Extension",
  "description": "在 VSCode 中提供一张承载 Agent、终端、任务和笔记的协作画布。",
  "version": "0.0.1",
  "publisher": "opencove",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.91.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:opencove.openCanvas",
    "onWebviewPanel:opencove.canvas"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "opencove.openCanvas",
        "title": "OpenCove: 打开画布"
      }
    ]
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reactflow": "11.11.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.80",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.17.19",
    "typescript": "^4.9.5"
  }
}
