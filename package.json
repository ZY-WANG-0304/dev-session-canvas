{
  "name": "dev-session-canvas",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.2.2",
  "publisher": "devsessioncanvas",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/ZY-WANG-0304/dev-session-canvas.git"
  },
  "homepage": "https://github.com/ZY-WANG-0304/dev-session-canvas",
  "bugs": {
    "url": "https://github.com/ZY-WANG-0304/dev-session-canvas/issues"
  },
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "AI",
    "Other"
  ],
  "keywords": [
    "ai",
    "agent",
    "canvas",
    "workbench",
    "multi-agent",
    "terminal",
    "note",
    "collaboration",
    "画布",
    "协作"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#102033",
    "theme": "dark"
  },
  "pricing": "Free",
  "qna": false,
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onCommand:devSessionCanvas.openCanvas",
    "onCommand:devSessionCanvas.openCanvasInEditor",
    "onCommand:devSessionCanvas.openCanvasInPanel",
    "onCommand:devSessionCanvas.openSettings",
    "onCommand:devSessionCanvas.createNode",
    "onCommand:devSessionCanvas.resetCanvasState",
    "onView:devSessionCanvas.sidebar",
    "onView:devSessionCanvas.sidebarFilters",
    "onView:devSessionCanvas.canvasPanel",
    "onWebviewPanel:devSessionCanvas.canvas"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "%capabilities.untrusted.description%",
      "restrictedConfigurations": [
        "devSessionCanvas.runtimePersistence.enabled",
        "devSessionCanvas.agent.defaultProvider",
        "devSessionCanvas.agent.codexCommand",
        "devSessionCanvas.agent.claudeCommand",
        "devSessionCanvas.agent.codexDefaultArgs",
        "devSessionCanvas.agent.claudeDefaultArgs",
        "devSessionCanvas.terminal.shellPath"
      ]
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "%capabilities.virtual.description%"
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "devSessionCanvas",
          "title": "%viewsContainer.canvas.title%",
          "icon": "images/dev-session-canvas-activitybar.svg"
        }
      ],
      "panel": [
        {
          "id": "devSessionCanvasPanel",
          "title": "%viewsContainer.canvasPanel.title%",
          "icon": "images/dev-session-canvas-activitybar.svg"
        }
      ]
    },
    "views": {
      "devSessionCanvas": [
        {
          "id": "devSessionCanvas.sidebar",
          "name": "%view.canvas.sidebar.summary.title%"
        },
        {
          "id": "devSessionCanvas.sidebarFilters",
          "name": "%view.canvas.sidebar.actions.title%",
          "type": "webview"
        }
      ],
      "devSessionCanvasPanel": [
        {
          "type": "webview",
          "id": "devSessionCanvas.canvasPanel",
          "name": "%view.canvas.panel.title%",
          "when": "devSessionCanvas.canvas.panelViewVisible"
        }
      ]
    },
    "commands": [
      {
        "command": "devSessionCanvas.openCanvas",
        "title": "%command.openCanvas.title%",
        "icon": "$(go-to-file)"
      },
      {
        "command": "devSessionCanvas.openCanvasInEditor",
        "title": "%command.openCanvasInEditor.title%"
      },
      {
        "command": "devSessionCanvas.openCanvasInPanel",
        "title": "%command.openCanvasInPanel.title%"
      },
      {
        "command": "devSessionCanvas.openSettings",
        "title": "%command.openSettings.title%",
        "icon": "$(settings-gear)"
      },
      {
        "command": "devSessionCanvas.createNode",
        "title": "%command.createNode.title%",
        "icon": "$(add)"
      },
      {
        "command": "devSessionCanvas.resetCanvasState",
        "title": "%command.resetCanvasState.title%",
        "icon": "$(discard)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "devSessionCanvas.openCanvas",
          "when": "view == devSessionCanvas.sidebarFilters",
          "group": "navigation@1"
        },
        {
          "command": "devSessionCanvas.openSettings",
          "when": "view == devSessionCanvas.sidebar",
          "group": "navigation@99"
        },
        {
          "command": "devSessionCanvas.createNode",
          "when": "view == devSessionCanvas.sidebarFilters",
          "group": "navigation@2"
        },
        {
          "command": "devSessionCanvas.resetCanvasState",
          "when": "view == devSessionCanvas.sidebarFilters",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "devSessionCanvas.canvas.defaultSurface": {
          "type": "string",
          "enum": [
            "editor",
            "panel"
          ],
          "default": "panel",
          "scope": "window",
          "markdownDescription": "%configuration.canvas.defaultSurface.description%"
        },
        "devSessionCanvas.runtimePersistence.enabled": {
          "type": "boolean",
          "default": false,
          "scope": "window",
          "markdownDescription": "%configuration.runtimePersistence.enabled.description%"
        },
        "devSessionCanvas.agent.defaultProvider": {
          "type": "string",
          "enum": [
            "codex",
            "claude"
          ],
          "default": "codex",
          "scope": "window",
          "markdownDescription": "%configuration.agent.defaultProvider.description%"
        },
        "devSessionCanvas.agent.codexCommand": {
          "type": "string",
          "default": "codex",
          "scope": "machine",
          "markdownDescription": "%configuration.agent.codexCommand.description%"
        },
        "devSessionCanvas.agent.claudeCommand": {
          "type": "string",
          "default": "claude",
          "scope": "machine",
          "markdownDescription": "%configuration.agent.claudeCommand.description%"
        },
        "devSessionCanvas.agent.codexDefaultArgs": {
          "type": "string",
          "default": "",
          "scope": "window",
          "markdownDescription": "%configuration.agent.codexDefaultArgs.description%"
        },
        "devSessionCanvas.agent.claudeDefaultArgs": {
          "type": "string",
          "default": "",
          "scope": "window",
          "markdownDescription": "%configuration.agent.claudeDefaultArgs.description%"
        },
        "devSessionCanvas.notifications.bridgeTerminalAttentionSignals": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "%configuration.notifications.bridgeTerminalAttentionSignals.description%"
        },
        "devSessionCanvas.notifications.strongTerminalAttentionReminder": {
          "type": "string",
          "enum": [
            "none",
            "titleBar",
            "minimap",
            "both"
          ],
          "default": "both",
          "scope": "window",
          "markdownDescription": "%configuration.notifications.strongTerminalAttentionReminder.description%",
          "markdownEnumDescriptions": [
            "%configuration.notifications.strongTerminalAttentionReminder.none.description%",
            "%configuration.notifications.strongTerminalAttentionReminder.titleBar.description%",
            "%configuration.notifications.strongTerminalAttentionReminder.minimap.description%",
            "%configuration.notifications.strongTerminalAttentionReminder.both.description%"
          ]
        },
        "devSessionCanvas.terminal.shellPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "%configuration.terminal.shellPath.description%"
        },
        "devSessionCanvas.files.enabled": {
          "type": "boolean",
          "default": true,
          "scope": "window",
          "markdownDescription": "%configuration.files.enabled.description%"
        },
        "devSessionCanvas.files.presentationMode": {
          "type": "string",
          "enum": [
            "nodes",
            "lists"
          ],
          "default": "nodes",
          "scope": "window",
          "markdownDescription": "%configuration.files.presentationMode.description%"
        },
        "devSessionCanvas.fileNode.displayStyle": {
          "type": "string",
          "enum": [
            "card",
            "minimal"
          ],
          "default": "minimal",
          "scope": "window",
          "markdownDescription": "%configuration.fileNode.displayStyle.description%"
        },
        "devSessionCanvas.files.nodeDisplayMode": {
          "type": "string",
          "enum": [
            "icon-path",
            "icon-only",
            "path-only"
          ],
          "default": "icon-path",
          "scope": "window",
          "markdownDescription": "%configuration.files.nodeDisplayMode.description%"
        },
        "devSessionCanvas.files.pathDisplayMode": {
          "type": "string",
          "enum": [
            "basename",
            "relative-path"
          ],
          "default": "basename",
          "scope": "window",
          "markdownDescription": "%configuration.files.pathDisplayMode.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "package": "npm run typecheck && node scripts/build.mjs --production",
    "package:vsix": "npm run package && node scripts/package-vsix.mjs",
    "postinstall": "node scripts/ensure-node-pty-helper-permissions.mjs",
    "test": "npm run typecheck && npm run test:workspace-relative-paths && npm run test:extension-storage-paths && npm run test:runtime-supervisor-paths && npm run test:execution-terminal-native-helpers && npm run test:execution-terminal-line-context-tracker && npm run test:execution-attention-signals && npm run test:agent-launch-presets && npm run test:smoke && npm run test:webview",
    "test:agent-launch-presets": "node scripts/test-agent-launch-presets.mjs",
    "test:extension-storage-paths": "node scripts/test-extension-storage-paths.mjs",
    "test:execution-attention-signals": "node scripts/test-execution-attention-signals.mjs",
    "test:execution-terminal-line-context-tracker": "node scripts/test-execution-terminal-line-context-tracker.mjs",
    "test:execution-terminal-native-helpers": "node scripts/test-execution-terminal-native-helpers.mjs",
    "test:runtime-supervisor-paths": "node scripts/test-runtime-supervisor-paths.mjs",
    "test:workspace-relative-paths": "node --no-warnings --experimental-transform-types scripts/test-workspace-relative-paths.mts",
    "test:vscode-smoke-runner-env": "node scripts/test-vscode-smoke-runner-env.mjs",
    "test:smoke": "npm run build && node scripts/run-vscode-smoke.mjs",
    "test:smoke-storage-slot": "npm run build && node scripts/run-vscode-storage-slot-smoke.mjs",
    "validate:clean-checkout:vsix": "node scripts/run-clean-checkout-vsix-validation.mjs",
    "test:vsix-smoke": "node scripts/run-vscode-vsix-smoke.mjs",
    "test:webview": "npm run build && node scripts/run-playwright-webview.mjs",
    "generate:marketplace-media": "node scripts/generate-marketplace-media.mjs",
    "vscode:prepublish": "npm run package",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "linkify-it": "^5.0.0",
    "node-pty": "^1.2.0-beta.12",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reactflow": "11.11.4"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "tmp": "0.2.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^18.19.80",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "cheerio": "1.0.0-rc.12",
    "esbuild": "^0.17.19",
    "tmp": "0.2.1",
    "typescript": "5.0.4"
  }
}
