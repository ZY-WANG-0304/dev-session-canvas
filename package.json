{
  "name": "opencove-extension",
  "displayName": "%extension.displayName%",
  "description": "%extension.description%",
  "version": "0.0.1",
  "publisher": "opencove",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "ssh://git@10.79.10.70:1022/ziyang01.wang/opencove_extension.git"
  },
  "homepage": "http://10.79.10.70:1080/ziyang01.wang/opencove_extension",
  "bugs": {
    "url": "http://10.79.10.70:1080/ziyang01.wang/opencove_extension/-/issues"
  },
  "preview": true,
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "agent",
    "canvas",
    "terminal",
    "task",
    "note",
    "collaboration",
    "画布",
    "协作"
  ],
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#102033",
    "theme": "dark"
  },
  "pricing": "Free",
  "qna": false,
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onCommand:opencove.openCanvas",
    "onCommand:opencove.createNode",
    "onCommand:opencove.resetCanvasState",
    "onWebviewPanel:opencove.canvas"
  ],
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "%capabilities.untrusted.description%",
      "restrictedConfigurations": [
        "opencove.agent.defaultProvider",
        "opencove.agent.codexCommand",
        "opencove.agent.claudeCommand",
        "opencove.terminal.shellPath"
      ]
    },
    "virtualWorkspaces": {
      "supported": false,
      "description": "%capabilities.virtual.description%"
    }
  },
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "opencove",
          "title": "%viewsContainer.opencove.title%",
          "icon": "images/opencove-activitybar.svg"
        }
      ]
    },
    "views": {
      "opencove": [
        {
          "id": "opencove.sidebar",
          "name": "%view.opencove.sidebar.title%"
        }
      ]
    },
    "commands": [
      {
        "command": "opencove.openCanvas",
        "title": "%command.openCanvas.title%"
      },
      {
        "command": "opencove.createNode",
        "title": "%command.createNode.title%"
      },
      {
        "command": "opencove.resetCanvasState",
        "title": "%command.resetCanvasState.title%"
      }
    ],
    "configuration": {
      "title": "%configuration.title%",
      "properties": {
        "opencove.agent.defaultProvider": {
          "type": "string",
          "enum": [
            "codex",
            "claude"
          ],
          "default": "codex",
          "scope": "window",
          "markdownDescription": "%configuration.agent.defaultProvider.description%"
        },
        "opencove.agent.codexCommand": {
          "type": "string",
          "default": "codex",
          "scope": "machine",
          "markdownDescription": "%configuration.agent.codexCommand.description%"
        },
        "opencove.agent.claudeCommand": {
          "type": "string",
          "default": "claude",
          "scope": "machine",
          "markdownDescription": "%configuration.agent.claudeCommand.description%"
        },
        "opencove.terminal.shellPath": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "markdownDescription": "%configuration.terminal.shellPath.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "package": "npm run typecheck && node scripts/build.mjs --production",
    "package:vsix": "npm run package && node scripts/package-vsix.mjs",
    "postinstall": "node scripts/ensure-node-pty-helper-permissions.mjs",
    "vscode:prepublish": "npm run package",
    "watch": "node scripts/build.mjs --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "reactflow": "11.11.4"
  },
  "overrides": {
    "cheerio": "1.0.0-rc.12",
    "tmp": "0.2.1"
  },
  "devDependencies": {
    "@types/node": "^18.19.80",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/vscode": "^1.85.0",
    "cheerio": "1.0.0-rc.12",
    "esbuild": "^0.17.19",
    "tmp": "0.2.1",
    "typescript": "5.0.4",
    "vsce": "1.103.1"
  }
}
