{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Dev Session Canvas",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--user-data-dir=${workspaceFolder}/.debug/extension-dev-host/user-data",
        "--profile=Dev Session Canvas Persistence Debug",
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "skipFiles": [
        "<node_internals>/**",
        "**/.vscode-server/**/extensions/**",
        "**/.vscode-server/**/server/extensions/**",
        "**/resources/app/extensions/**"
      ],
      "outFiles": ["${workspaceFolder}/dist/**/*.js"],
      "preLaunchTask": "build extension"
    }
  ]
}
