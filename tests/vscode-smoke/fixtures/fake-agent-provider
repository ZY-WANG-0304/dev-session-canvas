#!/usr/bin/env bash

set -uo pipefail

mode="start"
if [[ "${1-}" == "resume" ]]; then
  mode="resume"
  shift
fi

requested_resume_session_id="${1-}"
session_dir="${DEV_SESSION_CANVAS_FAKE_PROVIDER_STORAGE_PATH:-}"
session_file=""
session_id=""
initial_prompt_delay_seconds="0.45"
hide_pid="${DEV_SESSION_CANVAS_FAKE_PROVIDER_HIDE_PID:-0}"
flavor="${DEV_SESSION_CANVAS_FAKE_AGENT_FLAVOR:-generic}"

prefix="[fake-agent]"
if [[ "$flavor" == "codex" ]]; then
  prefix="[fake-codex]"
elif [[ "$flavor" == "claude" ]]; then
  prefix="[fake-claude]"
fi

if [[ -n "$session_dir" ]]; then
  mkdir -p "$session_dir"
  session_file="${session_dir%/}/last-session"
fi

if [[ "$mode" == "resume" ]]; then
  if [[ -z "$session_file" || ! -f "$session_file" ]]; then
    echo "${prefix} no resumable session"
    exit 19
  fi

  session_id="$(cat "$session_file")"
  if [[ -z "$requested_resume_session_id" ]]; then
    echo "${prefix} missing resume session id"
    exit 20
  fi
  if [[ "$requested_resume_session_id" != "$session_id" ]]; then
    echo "${prefix} resume session mismatch expected=${session_id} actual=${requested_resume_session_id}"
    exit 21
  fi
  if [[ "$hide_pid" == "1" ]]; then
    echo "${prefix} resumed session ${session_id}"
  else
    echo "${prefix} resumed session ${session_id} pid=$$"
  fi
else
  session_id="${DEV_SESSION_CANVAS_FAKE_PROVIDER_SESSION_ID:-session-$$}"
  if [[ -n "$session_file" ]]; then
    printf '%s\n' "$session_id" > "$session_file"
  fi
  if [[ "$hide_pid" == "1" ]]; then
    echo "${prefix} ready session=${session_id}"
  else
    echo "${prefix} ready pid=$$ session=${session_id}"
  fi
fi

print_prompt() {
  printf '> '
}

sleep "$initial_prompt_delay_seconds"
print_prompt

handle_signal() {
  echo "${prefix} received signal"
  exit 0
}

trap handle_signal TERM INT

while IFS= read -r line; do
  line="${line%$'\r'}"

  if [[ -z "$line" ]]; then
    continue
  fi

  if [[ "$line" == exit\ * ]]; then
    exit_code="${line#exit }"
    echo "${prefix} exiting with code ${exit_code}"
    exit "$exit_code"
  fi

  if [[ "$line" == burst\ * ]]; then
    burst_count="${line#burst }"
    if [[ "$burst_count" =~ ^[0-9]+$ ]]; then
      for ((i = 1; i <= burst_count; i += 1)); do
        printf '%s burst %03d\n' "$prefix" "$i"
      done
      print_prompt
      continue
    fi
  fi

  if [[ "$line" == sleep\ * ]]; then
    sleep_seconds="${line#sleep }"
    echo "${prefix} sleeping ${sleep_seconds}s"
    sleep "$sleep_seconds"
    echo "${prefix} woke after ${sleep_seconds}s"
    print_prompt
    continue
  fi

  if [[ "$line" == slowspin\ * ]]; then
    spin_count="${line#slowspin }"
    if [[ "$spin_count" =~ ^[0-9]+$ ]]; then
      frames=('-' '\\' '|' '/')
      for ((i = 1; i <= spin_count; i += 1)); do
        frame_index=$(((i - 1) % ${#frames[@]}))
        printf '\r%s %s slowspin %03d' "$prefix" "${frames[$frame_index]}" "$i"
        sleep 0.55
      done
      printf '\r%s slowspin done %03d\n' "$prefix" "$spin_count"
      print_prompt
      continue
    fi
  fi

  if [[ "$line" == "写一首打油诗" ]]; then
    echo "小站灯昏代码香"
    sleep 0.12
    echo "键盘敲出半行霜"
    sleep 0.12
    echo "若问今晚谁最忙"
    sleep 0.12
    echo "Code Worker 一边写诗一边扛"
    print_prompt
    continue
  fi

  if [[ "$line" == clear-demo ]]; then
    printf '\033[2J\033[H'
    print_prompt
    continue
  fi

  if [[ "$line" == raw\ * ]]; then
    printf '%s\n' "${line#raw }"
    print_prompt
    continue
  fi

  if [[ "$line" == notify\ * ]]; then
    notify_message="${line#notify }"
    printf '\033]9;%s\007' "$notify_message"
    printf '%s notified %s\n' "$prefix" "$notify_message"
    print_prompt
    continue
  fi

  echo "${prefix} ${line}"
  print_prompt
done
