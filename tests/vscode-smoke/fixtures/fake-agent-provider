#!/usr/bin/env bash

set -uo pipefail

mode="start"
if [[ "${1-}" == "resume" ]]; then
  mode="resume"
  shift
fi

session_dir="${CODEX_HOME:-}"
session_file=""
session_id=""

if [[ -n "$session_dir" ]]; then
  mkdir -p "$session_dir"
  session_file="${session_dir%/}/last-session"
fi

if [[ "$mode" == "resume" ]]; then
  if [[ -z "$session_file" || ! -f "$session_file" ]]; then
    echo "[fake-agent] no resumable session"
    exit 19
  fi

  session_id="$(cat "$session_file")"
  echo "[fake-agent] resumed session ${session_id} pid=$$"
else
  session_id="session-$$"
  if [[ -n "$session_file" ]]; then
    printf '%s\n' "$session_id" > "$session_file"
  fi
  echo "[fake-agent] ready pid=$$ session=${session_id}"
fi

handle_signal() {
  echo "[fake-agent] received signal"
  exit 0
}

trap handle_signal TERM INT

while IFS= read -r line; do
  line="${line%$'\r'}"

  if [[ -z "$line" ]]; then
    continue
  fi

  if [[ "$line" == exit\ * ]]; then
    exit_code="${line#exit }"
    echo "[fake-agent] exiting with code ${exit_code}"
    exit "$exit_code"
  fi

  if [[ "$line" == burst\ * ]]; then
    burst_count="${line#burst }"
    if [[ "$burst_count" =~ ^[0-9]+$ ]]; then
      for ((i = 1; i <= burst_count; i += 1)); do
        printf '[fake-agent] burst %03d\n' "$i"
      done
      continue
    fi
  fi

  if [[ "$line" == sleep\ * ]]; then
    sleep_seconds="${line#sleep }"
    echo "[fake-agent] sleeping ${sleep_seconds}s"
    sleep "$sleep_seconds"
    echo "[fake-agent] woke after ${sleep_seconds}s"
    continue
  fi

  echo "[fake-agent] ${line}"
done
